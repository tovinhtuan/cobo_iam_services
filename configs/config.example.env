# Copy to .env or export before running (example values).
SERVICE_NAME=cobo_iam_services
ENV=development
LOG_LEVEL=info

# API
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# Worker
WORKER_TICK_INTERVAL=5s

# MySQL (optional for P0.1 bootstrap; required for /readyz = ready).
# When set, API + worker use table `outbox_events` for durable outbox (MySQL 8+ for SKIP LOCKED).
# Use parseTime=true and loc=UTC for TIMESTAMP columns.
# MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/cobo_iam?parseTime=true&loc=UTC&tls=false

# Redis (optional P2.2): shared effective-access projection cache for API instances.
# If REDIS_ADDR is set but Redis is unreachable at startup, API falls back to in-memory cache.
# REDIS_ADDR=127.0.0.1:6379
# REDIS_PASSWORD=
# REDIS_DB=0
# EFFECTIVE_ACCESS_CACHE_TTL=5m

# Access token migration mode:
# - opaque: current stable behavior
# - dual: issue JWT, verify JWT first then opaque fallback (migration)
# - jwt: JWT only
ACCESS_TOKEN_MODE=opaque
ACCESS_TOKEN_TTL=15m

# JWT settings (used for jwt/dual modes)
JWT_ISSUER=cobo_iam_services
JWT_AUDIENCE=cobo_clients
JWT_ALG=EdDSA
# JWT_SIGNING_PRIVATE_KEY_PEM=
# JWT_VERIFY_PUBLIC_KEYS_JSON=
JWT_CLOCK_SKEW_SEC=60

# Web base URL for email action links
PUBLIC_WEB_BASE_URL=http://localhost:5173

# SMTP (worker): if SMTP_HOST is empty, worker logs email payload instead of sending.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@cobo.vn
